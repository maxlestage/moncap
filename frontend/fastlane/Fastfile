default_platform(:ios)

APP_IDENTIFIER = "com.maxlestage.moncap"
TEAM_ID = "2FW8T4UX4L"

platform :ios do
  desc "Archive et envoie une build sur TestFlight"
  lane :beta do
    # Prépare un trousseau temporaire sur le runner CI.
    setup_ci

    # Authentification App Store Connect (clé API : aucun mot de passe, ni 2FA).
    key_content = ENV.fetch("ASC_KEY_CONTENT")
    is_base64 = !key_content.include?("BEGIN PRIVATE KEY")
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: key_content,
      is_key_content_base64: is_base64,
      in_house: false
    )

    # Certificat de distribution + profil App Store, générés une fois et
    # réutilisés depuis le dépôt privé chiffré (fastlane match).
    match(
      type: "appstore",
      api_key: api_key,
      readonly: false
    )
    profile_name = ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-name"]

    # Signature manuelle avec le profil fourni par match.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "MonCapGPS.xcodeproj",
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      bundle_identifier: APP_IDENTIFIER,
      profile_name: profile_name
    )

    # Numéro de build = dernier sur TestFlight + 1 (0 si aucune build).
    latest = begin
      latest_testflight_build_number(
        api_key: api_key,
        app_identifier: APP_IDENTIFIER,
        initial_build_number: 0
      )
    rescue StandardError
      0
    end
    build_number = latest + 1

    build_app(
      project: "MonCapGPS.xcodeproj",
      scheme: "MonCapGPS",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { APP_IDENTIFIER => profile_name }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
