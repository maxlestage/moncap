default_platform(:ios)

APP_IDENTIFIER = "com.maxlestage.moncap"

platform :ios do
  desc "Archive et envoie une build sur TestFlight"
  lane :beta do
    # Authentification via clé App Store Connect API (aucun mot de passe, ni 2FA).
    # Les 3 valeurs viennent des secrets GitHub (voir README).
    key_content = ENV.fetch("ASC_KEY_CONTENT")
    # Détecte automatiquement si le secret contient le .p8 brut ou du base64.
    is_base64 = !key_content.include?("BEGIN PRIVATE KEY")
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: key_content,
      is_key_content_base64: is_base64,
      in_house: false
    )

    # Numéro de build = dernier sur TestFlight + 1 (0 si l'app n'a pas encore
    # de build). Évite les collisions de numéro de build.
    latest = begin
      latest_testflight_build_number(
        api_key: api_key,
        app_identifier: APP_IDENTIFIER,
        initial_build_number: 0
      )
    rescue StandardError
      0
    end
    build_number = latest + 1

    # Archive en Release. La signature est gérée automatiquement par Xcode via
    # la clé API (-allowProvisioningUpdates), donc aucun certificat à fournir.
    build_app(
      project: "MonCapGPS.xcodeproj",
      scheme: "MonCapGPS",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      xcargs: "-allowProvisioningUpdates CURRENT_PROJECT_VERSION=#{build_number}"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
