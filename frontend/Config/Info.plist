<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Navigation en arrière-plan : suivi GPS + annonces vocales écran
	     verrouillé. Les autres clés sont générées par Xcode
	     (GENERATE_INFOPLIST_FILE = YES fusionne avec ce fichier). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>audio</string>
	</array>
	<!-- Écran de lancement natif : fond bleu de marque (évite le flash blanc
	     avant l'apparition de la vue SwiftUI de chargement). -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
</dict>
</plist>
