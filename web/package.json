{
  "name": "moncap-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot ./index.html",
    "build": "rm -rf dist && bun build ./index.html --outdir dist --minify",
    "serve": "bun run build && bun static-server.ts 8080 dist"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5"
  }
}
